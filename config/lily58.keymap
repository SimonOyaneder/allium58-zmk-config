#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/ext_power.h>
#include <dt-bindings/zmk/keys.h>

/ {
    behaviors {
        // Tecla ñ: escribe ñ directo, y Ñ con Shift.

        es_n: es_n {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&n_tilde>, <&n_tilde_up>;

            mods = <(MOD_LSFT|MOD_RSFT)>;
        };

        // Tecla muerta de acento, igual que en el layout de España:
        // se presiona y la siguiente vocal sale acentuada (á é í ó ú).
        // Con Shift es la diéresis muerta (¨) para escribir ü.
        // Requiere macOS con distribución "U.S." o "ABC" (Option+E / Option+U).

        es_acute: es_acute {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp LA(E)>, <&kp LA(U)>;

            mods = <(MOD_LSFT|MOD_RSFT)>;
        };

        // Coma y punto al estilo del layout de España:
        // "," con Shift da ";" y "." con Shift da ":".

        es_comma: es_comma {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp COMMA>, <&kp SEMI>;

            mods = <(MOD_LSFT|MOD_RSFT)>;
        };

        es_dot: es_dot {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp DOT>, <&kp COLON>;

            mods = <(MOD_LSFT|MOD_RSFT)>;
        };
    };

    macros {
        windows: Windows {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&to 0 &bt BT_SEL 0>;
            label = "WINDOWS";
        };

        mac: mac {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&to 0 &bt BT_SEL 1>;
            label = "MAC";
        };

        // ñ para macOS con distribución "U.S."/"ABC":
        // Option+N activa la virgulilla muerta y luego se escribe la n.

        n_tilde: n_tilde {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LA(N) &kp N>;
        };

        n_tilde_up: n_tilde_up {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LA(N) &kp LS(N)>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        Mac {
            /* MAC (base)
             * ,-----------------------------------------.                    ,-----------------------------------------.
             * | ESC  |  1   |  2   |  3   |  4   |  5   |                    |  6   |  7   |  8   |  9   |  0   | BkSp |
             * |------+------+------+------+------+------|                    |------+------+------+------+------+------|
             * | Tab  |  Q   |  W   |  E   |  R   |  T   |                    |  Y   |  U   |  I   |  O   |  P   |Enter |
             * |------+------+------+------+------+------|                    |------+------+------+------+------+------|
             * | Caps |  A   |  S   |  D   |  F   |  G   |-------.    ,-------|  H   |  J   |  K   |  L   |  Ñ   | ´ ¨  |
             * |------+------+------+------+------+------| HIGH  |    |  LOW  |------+------+------+------+------+------|
             * |Shift |  Z   |  X   |  C   |  V   |  B   |-------|    |-------|  N   |  M   | , ;  | . :  | - _  |Shift |
             * `-----------------------------------------/       /     \      \-----------------------------------------'
             *                   |LCtrl | LAlt | LCmd | /Space  /       \Space \  | RCmd | RAlt | Del  |
             *                   |      |      |      |/       /         \      \ |      |      |      |
             *                   `----------------------------'           '------''--------------------'
             *
             * Comportamiento estilo teclado español (con macOS en layout "U.S."/"ABC"):
             *   Ñ escribe ñ/Ñ  ·  ´¨ es tecla muerta de acento (Shift: diéresis)
             *   , . - con Shift dan ; : _ como en el layout de España
             */

            bindings = <
&kp ESCAPE        &kp N1  &kp N2  &kp N3        &kp N4  &kp N5                                 &kp N6             &kp N7  &kp N8         &kp N9   &kp N0     &kp BACKSPACE
&kp TAB           &kp Q   &kp W   &kp E         &kp R   &kp T                                  &kp Y              &kp U   &kp I          &kp O    &kp P      &kp ENTER
&kp LEFT_CONTROL  &kp A   &kp S   &kp D         &kp F   &kp G                                  &kp H              &kp J   &kp K          &kp L    &es_n      &es_acute
&kp LEFT_SHIFT    &kp Z   &kp X   &kp C         &kp V   &kp B          &trans       &trans     &kp N              &kp M   &es_comma      &es_dot  &kp MINUS  &kp RIGHT_SHIFT
                                  &kp LEFT_ALT  &mo 1   &kp LEFT_META  &kp SPACE    &kp SPACE  &kp RIGHT_COMMAND  &mo 2   &kp RIGHT_ALT
            >;

            label = "Mac";
        };

        High {
            /* HIGH (símbolos de programación) — se activa manteniendo la tecla HIGH
             * ,-----------------------------------------.                    ,-----------------------------------------.
             * |      |      |      |      |      |      |                    |      |      |      |      |      |      |
             * |------+------+------+------+------+------|                    |------+------+------+------+------+------|
             * |      |      |      |      |      |      |                    |  ?   |  {   |  }   |  !   |  \   |      |
             * |------+------+------+------+------+------|                    |------+------+------+------+------+------|
             * |      |      |      |      |      |      |-------.    ,-------|  ¿   |  [   |  ]   |  ¡   |  ;   |  '   |
             * |------+------+------+------+------+------|       |    |       |------+------+------+------+------+------|
             * |      |      |      |      |      |      |-------|    |-------|  `   |  <   |  >   |  =   |  /   |      |
             * `-----------------------------------------/       /     \      \-----------------------------------------'
             *                   |      |      |      | /       /       \      \  |      |      |      |
             *                   |      |      |      |/       /         \      \ |      |      |      |
             *                   `----------------------------'           '------''--------------------'
             *
             * Lógica: la columna de U/J/M abre ({ [ <) y la de I/K/, cierra (} ] >).
             * El signo invertido va debajo del derecho (? sobre ¿ y ! sobre ¡).
             * Con Shift salen los pares de US: \ da | · ; da : · ' da " · ` da ~ · = da + · / da ?
             * ¿ y ¡ usan combos de Option (solo macOS con layout U.S.). Encoder: volumen.
             */

            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans                    &trans            &trans    &trans    &trans      &trans    &trans
&trans  &trans  &trans  &trans  &trans  &trans                    &kp QUESTION      &kp LBRC  &kp RBRC  &kp EXCL    &kp BSLH  &trans
&trans  &trans  &trans  &trans  &trans  &trans                    &kp LA(LS(FSLH))  &kp LBKT  &kp RBKT  &kp LA(N1)  &kp SEMI  &kp SQT
&trans  &trans  &trans  &trans  &trans  &trans  &trans    &trans  &kp GRAVE         &kp LT    &kp GT    &kp EQUAL   &kp FSLH  &trans
                        &trans  &trans  &trans  &trans    &trans  &trans            &trans    &trans
            >;

            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN>;
            label = "High";
        };

        Low {
            /* LOW (funciones, Bluetooth, media y flechas) — se activa manteniendo la tecla LOW
             * ,-----------------------------------------.                    ,-----------------------------------------.
             * |      |  F1  |  F2  |  F3  |  F4  |  F5  |                    |  F6  |  F7  |  F8  |  F9  | F10  | F11  |
             * |------+------+------+------+------+------|                    |------+------+------+------+------+------|
             * | BT 1 | BT 2 | BT 3 |      |      |BT CLR|                    | Prev | Vol- | Play | Vol+ | Next | F12  |
             * |------+------+------+------+------+------|                    |------+------+------+------+------+------|
             * |      |      |      |      |      |      |-------.    ,-------|      |  <-  |  ^   |  v   |  ->  |      |
             * |------+------+------+------+------+------|       |    |       |------+------+------+------+------+------|
             * |EP TOG|      |      |      |      |      |-------|    |-------| KP + |      |      |      |      |UNLCK |
             * `-----------------------------------------/       /     \      \-----------------------------------------'
             *                   |      |      |      | /       /       \      \  |      |      |      |
             *                   |      |      |      |/       /         \      \ |      |      |      |
             *                   `----------------------------'           '------''--------------------'
             *
             * BT 1-3 cambia de perfil Bluetooth (1=Windows, 2=Mac) y BT CLR borra el emparejamiento del perfil activo.
             * EP TOG enciende/apaga las pantallas nice!view. UNLCK desbloquea ZMK Studio. Encoder: volumen.
             */

            bindings = <
&trans             &kp F1        &kp F2        &kp F3  &kp F4  &kp F5                        &kp F6          &kp F7             &kp F8            &kp F9           &kp F10          &kp F11
&bt BT_SEL 0       &bt BT_SEL 1  &bt BT_SEL 2  &trans  &trans  &bt BT_CLR                    &kp C_PREVIOUS  &kp C_VOLUME_DOWN  &kp C_PLAY_PAUSE  &kp C_VOLUME_UP  &kp C_NEXT       &kp F12
&trans             &trans        &trans        &trans  &trans  &trans                        &trans          &kp LEFT_ARROW     &kp UP_ARROW      &kp DOWN_ARROW   &kp RIGHT_ARROW  &trans
&ext_power EP_TOG  &trans        &trans        &trans  &trans  &trans      &trans    &trans  &kp KP_PLUS     &trans             &trans            &trans           &trans           &studio_unlock
                                               &trans  &trans  &trans      &trans    &trans  &trans          &trans             &trans
            >;

            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN>;
            label = "Low";
        };
    };
};
